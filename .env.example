# ─────────────────────────────────────────────────────────────
# Mahu Plexus — Variables de entorno
# Copia este archivo como .env.local y completa tus valores.
# En Vercel: Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL — REQUERIDO en producción para enlaces de verificación/recuperación
# Desarrollo: http://localhost:3000
# Producción: https://tu-dominio.vercel.app
NEXT_PUBLIC_APP_URL=

# Izipay (pagos) — credenciales del Back Office Vendedor (Configuración → Claves de API REST)
# Usa credenciales de TEST en desarrollo y de PRODUCCIÓN en producción. No uses valores ficticios.
IZIPAY_USERNAME=
IZIPAY_PASSWORD=
NEXT_PUBLIC_IZIPAY_PUBLIC_KEY=
# Opcional: clave HMAC-SHA256 para validar el retorno del navegador (kr-hash)
IZIPAY_HMAC_KEY=
# Opcional: endpoint REST (por defecto https://api.micuentaweb.pe)
IZIPAY_API_BASE=

# Factiliza (consulta DNI/RUC)
DNI_API_TOKEN=
